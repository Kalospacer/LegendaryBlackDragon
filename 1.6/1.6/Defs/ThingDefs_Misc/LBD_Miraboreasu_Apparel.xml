<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<ThingDef ParentName="ApparelMakeableBase">
		<defName>LBD_Miraboreasu_Armor</defName>
		<label>Miraboreasu Armor</label>
    <description>Miraboreasu's armor possesses powerful protection, providing the creature with all-around resistance to damage. However, while wearing this armor, the super-regeneration ability cannot be activated.</description>
    <graphicData>
			<texPath>LegendaryBlackDragon/Things/Miraboreasu/Clothes/Armor/Miraboreasu_Armor</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutComplex</shaderType>
		</graphicData>
    <generateCommonality>0.0001</generateCommonality>
	  <destroyOnDrop>true</destroyOnDrop>
		<costStuffCount>0</costStuffCount>
    <useHitPoints>false</useHitPoints>
		<tradeTags Inherit="False"/>
    <tradeability>None</tradeability>
    <thingCategories>
      <li>ApparelArmor</li>
    </thingCategories>
    <apparel>
      <tags>
			  <li>LBD_Miraboreasu_Cloth</li>
      </tags>
			<bodyPartGroups>
        <li>FullHead</li>
				<li>Neck</li>
				<li>Torso</li>
				<li>Shoulders</li>
				<li>Arms</li>
				<li>Legs</li>
			</bodyPartGroups>
      <renderSkipFlags>
        <li>None</li>
      </renderSkipFlags>
			<wornGraphicPath>LegendaryBlackDragon/Things/Miraboreasu/Clothes/Armor/Miraboreasu_Armor</wornGraphicPath>
			<layers>
        <li>Middle</li>
			</layers>
      <canBeDesiredForIdeo>false</canBeDesiredForIdeo>
      <canBeGeneratedToSatisfyWarmth>false</canBeGeneratedToSatisfyWarmth>
      <canBeGeneratedToSatisfyToxicEnvironmentResistance>false</canBeGeneratedToSatisfyToxicEnvironmentResistance>
      <useWornGraphicMask>true</useWornGraphicMask>
    </apparel>
    <colorGenerator Class="ColorGenerator_Options">
      <options>
        <li>
          <weight>10</weight>
          <only>(1,1,1,1)</only>
        </li>
      </options>
    </colorGenerator>
    <recipeMaker Inherit="False" IsNull="True"/>
    <costList Inherit="False"/>
		<statBases>
			<WorkToMake>25000</WorkToMake>
			<Mass>0.5</Mass>
			<Flammability>0</Flammability>
			<EquipDelay>1</EquipDelay>

      <ArmorRating_Blunt>1</ArmorRating_Blunt>
      <ArmorRating_Sharp>1</ArmorRating_Sharp>
      <ArmorRating_Heat>1</ArmorRating_Heat>
		</statBases>
		<equippedStatOffsets>
      <IncomingDamageFactor>-0.5</IncomingDamageFactor>
		</equippedStatOffsets>
	</ThingDef>
