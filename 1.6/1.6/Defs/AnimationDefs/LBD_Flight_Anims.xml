<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <!-- 翅膀飞行 -->
  <AnimationDef>
    <defName>LBD_FlyEast</defName>
    <durationTicks>32</durationTicks>
    <keyframeParts>
      <li>
        <key>LBD_Flight_Attachment</key>
        <value>
          <keyframes>
            <li><graphicState>LBD_FlyEast_0</graphicState><tick>4</tick></li>
            <li><graphicState>LBD_FlyEast_1</graphicState><tick>8</tick></li>
            <li><graphicState>LBD_FlyEast_2</graphicState><tick>12</tick></li>
            <li><graphicState>LBD_FlyEast_3</graphicState><tick>16</tick></li>
            <li><graphicState>LBD_FlyEast_4</graphicState><tick>20</tick></li>
            <li><graphicState>LBD_FlyEast_3</graphicState><tick>24</tick></li>
            <li><graphicState>LBD_FlyEast_2</graphicState><tick>28</tick></li>
            <li><graphicState>LBD_FlyEast_1</graphicState><tick>32</tick></li>
          </keyframes>
        </value>
      </li>
      <li>
        <key>Root</key>
        <value><workerType>AnimationWorker_Keyframes</workerType><keyframes>
            <li><tick>0</tick><offset>(0,0,-0.05)</offset></li>
            <li><tick>18</tick><offset>(0,0,0.05)</offset></li>
            <li><tick>32</tick><offset>(0,0,-0.05)</offset></li>
          </keyframes></value>
      </li>
    </keyframeParts>
  </AnimationDef>
