<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <HediffDef>
    <defName>LBD_DRM_ArmorMeltdown</defName>
    <label>Armor Meltdown</label>
    <description>This person's armor is melting down due to extreme heat.</description>
    <defaultLabelColor>(1, 1, 0.8)</defaultLabelColor>
    <hediffClass>HediffWithComps</hediffClass>
    <comps>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDay>-4</severityPerDay>
      </li>
      <li Class="HediffCompProperties_DisappearsOnDeath" />
    </comps>
    <stages>
      <li>
        <label>minor</label>
        <becomeVisible>false</becomeVisible>
      </li>
      <li>
        <label>minor</label>
        <minSeverity>0.2</minSeverity>
        <statOffsets>
          <ArmorRating_Heat>-0.15</ArmorRating_Heat>
        </statOffsets>
        <damageFactors>
          <Flame>2</Flame>
          <Burn>2</Burn>
          <LBD_DRM_Flame>2</LBD_DRM_Flame>
        </damageFactors>
      </li>
      <li>
        <label>moderate</label>
        <minSeverity>0.35</minSeverity>
        <statOffsets>
          <ArmorRating_Heat>-0.35</ArmorRating_Heat>
        </statOffsets>
        <damageFactors>
          <Flame>3.5</Flame>
          <Burn>3.5</Burn>
          <LBD_DRM_Flame>3.5</LBD_DRM_Flame>
        </damageFactors>
      </li>
      <li>
        <label>serious</label>
        <minSeverity>0.5</minSeverity>
        <statOffsets>
          <ArmorRating_Heat>-0.65</ArmorRating_Heat>
        </statOffsets>
        <damageFactors>
          <Flame>4.5</Flame>
          <Burn>4.5</Burn>
          <LBD_DRM_Flame>4.5</LBD_DRM_Flame>
        </damageFactors>
      </li>
      <li>
        <label>extreme</label>
        <minSeverity>0.65</minSeverity>
        <statOffsets>
          <ArmorRating_Heat>-0.8</ArmorRating_Heat>
        </statOffsets>
        <damageFactors>
          <Flame>6</Flame>
          <Burn>6</Burn>
          <LBD_DRM_Flame>6</LBD_DRM_Flame>
        </damageFactors>
      </li>
      <li>
        <label>completely melted</label>
        <minSeverity>0.85</minSeverity>
        <statOffsets>
          <ArmorRating_Heat>-2</ArmorRating_Heat>
        </statOffsets>
        <damageFactors>
          <Flame>8</Flame>
          <Burn>8</Burn>
          <LBD_DRM_Flame>8</LBD_DRM_Flame>
        </damageFactors>
      </li>
    </stages>
  </HediffDef>
  <HediffDef>
    <defName>LBD_Angry_Bluefire</defName>
    <label>Overpressure</label>
    <description>The head remains undamaged, and the breath is currently at its most powerful state!</description>
    <hediffClass>HediffWithComps</hediffClass>
    <everCurableByItem>false</everCurableByItem>
    <duplicationAllowed>false</duplicationAllowed>
    <keepOnBodyPartRestoration>True</keepOnBodyPartRestoration>
    <isBad>false</isBad>
    <stages>
      <li>
        <statFactors>
          <MeleeDamageFactor>2</MeleeDamageFactor>
        </statFactors>
        <damageFactors>
					<LBD_DRM_Flame>0</LBD_DRM_Flame>
				</damageFactors>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <showRemainingTime>true</showRemainingTime>
      </li>
      <li Class="HediffCompProperties_DisappearsOnDeath"/>
    </comps>
  </HediffDef>
  <HediffDef>
    <defName>LBD_Dragon_Regeneration</defName>
    <label>Super-regeneration</label>
    <description>Miraboreasu's body is composed of some supernatural force. As long as there is some rest time, all damage will be automatically healed.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <everCurableByItem>false</everCurableByItem>
    <duplicationAllowed>false</duplicationAllowed>
    <keepOnBodyPartRestoration>True</keepOnBodyPartRestoration>
    <isBad>false</isBad>
    <stages>
      <li>
      </li>
    </stages>
    <comps>
      <li Class="LegendaryBlackDragon.HediffCompProperties_Regeneration">
        <activeSeverity>0.5</activeSeverity>
        <inactiveSeverity>1.5</inactiveSeverity>
        <repairCooldownAfterDamage>600</repairCooldownAfterDamage>
      </li>
      <li Class="HediffCompProperties_RemoveIfApparelDropped" />
    </comps>
  </HediffDef>
  <HediffDef ParentName="InjuryBase">
    <defName>LBD_DragonLanceStab</defName>
    <label>Dragonator Wound</label>
    <labelNoun>A wound left by a Dragonator pierce.</labelNoun>
    <description>A wound left by a Dragonator pierce.</description>
    <duplicationAllowed>false</duplicationAllowed>
    <injuryProps>
      <painPerSeverity>9999</painPerSeverity>
      <averagePainPerSeverityPermanent>9999</averagePainPerSeverityPermanent>
      <bleedRate>0</bleedRate>
      <canMerge>false</canMerge>
      <destroyedLabel>Cut off</destroyedLabel>
      <destroyedOutLabel>Cut out</destroyedOutLabel>
    </injuryProps>
    <comps>
      <li Class="HediffCompProperties_TendDuration">
        <labelTendedWell>bandaged</labelTendedWell>
        <labelTendedWellInner>sutured</labelTendedWellInner>
        <labelSolidTendedWell>set</labelSolidTendedWell>
      </li>
    </comps>
  </HediffDef>
  <HediffDef>
    <defName>LBD_Need_LBD_BlackDragon_Change</defName>
    <label>Flame Breath</label>
    <description>Hooooooo~</description>
    <hediffClass>Hediff_High</hediffClass>
    <everCurableByItem>false</everCurableByItem>
    <duplicationAllowed>false</duplicationAllowed>
    <keepOnBodyPartRestoration>True</keepOnBodyPartRestoration>
    <isBad>false</isBad>
    <stages>
      <li>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_DisappearsDisableable">
        <disappearsAfterTicks>600</disappearsAfterTicks>
        <showRemainingTime>true</showRemainingTime>
      </li>
      <li Class="HediffCompProperties_ChangeNeed">
        <needDef>Need_LBD_BlackDragon</needDef>
        <percentPerDay>100</percentPerDay>
      </li> 
    </comps>
  </HediffDef>
  <ThoughtDef>
    <defName>LBD_Angry_Bluefire_Switch_Though</defName>
    <workerClass>ThoughtWorker_Hediff</workerClass>
    <hediff>LBD_Angry_Bluefire</hediff>
    <validWhileDespawned>true</validWhileDespawned>
    <developmentalStageFilter>Baby, Child, Adult</developmentalStageFilter>
    <stages>
      <li>
        <label>Angry</label>
        <description>Can you die faster?</description>
        <baseMoodEffect>-10</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>
</Defs>
