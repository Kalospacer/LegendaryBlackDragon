<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <HediffDef>
    <defName>LBD_DRM_ArmorMeltdown</defName>
    <label>armor meltdown</label>
    <description>This person's armor is melting down due to heat effects.</description>
    <defaultLabelColor>(1, 1, 0.8)</defaultLabelColor>
    <hediffClass>HediffWithComps</hediffClass>
    <comps>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDay>-4</severityPerDay>
      </li>
      <li Class="HediffCompProperties_DisappearsOnDeath" />
    </comps>
    <stages>
      <li>
        <label>minor</label>
        <becomeVisible>false</becomeVisible>
      </li>
      <li>
        <label>minor</label>
        <minSeverity>0.2</minSeverity>
        <statOffsets>
          <ArmorRating_Heat>-0.15</ArmorRating_Heat>
        </statOffsets>
        <damageFactors>
          <Flame>2</Flame>
          <Burn>2</Burn>
          <LBD_DRM_Flame>2</LBD_DRM_Flame>
        </damageFactors>
      </li>
      <li>
        <label>moderate</label>
        <minSeverity>0.35</minSeverity>
        <statOffsets>
          <ArmorRating_Heat>-0.35</ArmorRating_Heat>
        </statOffsets>
        <damageFactors>
          <Flame>3.5</Flame>
          <Burn>3.5</Burn>
          <LBD_DRM_Flame>3.5</LBD_DRM_Flame>
        </damageFactors>
      </li>
      <li>
        <label>serious</label>
        <minSeverity>0.5</minSeverity>
        <statOffsets>
          <ArmorRating_Heat>-0.65</ArmorRating_Heat>
        </statOffsets>
        <damageFactors>
          <Flame>4.5</Flame>
          <Burn>4.5</Burn>
          <LBD_DRM_Flame>4.5</LBD_DRM_Flame>
        </damageFactors>
      </li>
      <li>
        <label>extreme</label>
        <minSeverity>0.65</minSeverity>
        <statOffsets>
          <ArmorRating_Heat>-0.8</ArmorRating_Heat>
        </statOffsets>
        <damageFactors>
          <Flame>6</Flame>
          <Burn>6</Burn>
          <LBD_DRM_Flame>6</LBD_DRM_Flame>
        </damageFactors>
      </li>
      <li>
        <label>completely</label>
        <minSeverity>0.85</minSeverity>
        <statOffsets>
          <ArmorRating_Heat>-2</ArmorRating_Heat>
        </statOffsets>
        <damageFactors>
          <Flame>8</Flame>
          <Burn>8</Burn>
          <LBD_DRM_Flame>8</LBD_DRM_Flame>
        </damageFactors>
      </li>
    </stages>
  </HediffDef>
  <HediffDef>
    <defName>LBD_Angry_Bluefire</defName>
    <label>核心超压</label>
    <description>喜报：头部没有受到破坏，吐息目前处于威力最强的状态！</description>
    <hediffClass>HediffWithComps</hediffClass>
    <everCurableByItem>false</everCurableByItem>
    <duplicationAllowed>false</duplicationAllowed>
    <keepOnBodyPartRestoration>True</keepOnBodyPartRestoration>
    <isBad>false</isBad>
    <stages>
      <li>
        <statFactors>
          <MeleeDamageFactor>2</MeleeDamageFactor>
        </statFactors>
        <damageFactors>
					<LBD_DRM_Flame>0</LBD_DRM_Flame>
				</damageFactors>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <showRemainingTime>true</showRemainingTime>
      </li>
      <li Class="HediffCompProperties_DisappearsOnDeath"/>
    </comps>
  </HediffDef>
  <HediffDef>
    <defName>LBD_Dragon_Regeneration</defName>
    <label>超速愈合</label>
    <description>黑龙的身躯是由某种超自然力量构成的，只要有一定的休息时间，所有的伤害都会被自动治愈。</description>
    <hediffClass>HediffWithComps</hediffClass>
    <everCurableByItem>false</everCurableByItem>
    <duplicationAllowed>false</duplicationAllowed>
    <keepOnBodyPartRestoration>True</keepOnBodyPartRestoration>
    <isBad>false</isBad>
    <stages>
      <li>
        <statFactors>
          <MeleeDamageFactor>2</MeleeDamageFactor>
        </statFactors>
        <damageFactors>
					<LBD_DRM_Flame>0</LBD_DRM_Flame>
				</damageFactors>
      </li>
    </stages>
    <comps>
      <li Class="LegendaryBlackDragon.HediffCompProperties_Regeneration">
        <activeSeverity>0.5</activeSeverity>
        <inactiveSeverity>1.5</inactiveSeverity>
        <repairCooldownAfterDamage>600</repairCooldownAfterDamage>
      </li>
      <li Class="HediffCompProperties_RemoveIfApparelDropped" />
    </comps>
  </HediffDef>
</Defs>
