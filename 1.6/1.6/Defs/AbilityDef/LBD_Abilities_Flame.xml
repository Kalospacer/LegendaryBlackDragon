<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <AbilityDef>
    <defName>LBD_Angry_Bluefire_Switch</defName>
    <label>红温</label>
    <description>因为无法快速解决蝼蚁而感到烦闷，黑龙打算释放她最恐怖的毁灭之力。在这种情况下，黑龙的近战能力和火焰喷吐能力将得到极大的加强，但是心情会下降一段时间。</description>
    <iconPath>LegendaryBlackDragon/UI/Abilities/LBD_Angry_Bluefire_Switch</iconPath>
    <cooldownTicksRange>120000</cooldownTicksRange>    <!-- 2 days -->
    <hostile>false</hostile>
    <displayGizmoWhileUndrafted>false</displayGizmoWhileUndrafted>
    <disableGizmoWhileUndrafted>false</disableGizmoWhileUndrafted>
    <aiCanUse>true</aiCanUse>
    <ai_IsOffensive>true</ai_IsOffensive>
    <targetRequired>false</targetRequired>
    <jobDef>LBD_CastAbility_Angry</jobDef> <!-- 添加jobDef -->
    <waitForJobEnd>true</waitForJobEnd>
    <warmupStartSound>LBD_Dragon_Ability_Warmup</warmupStartSound>
    <statBases>
      <Ability_Duration>960</Ability_Duration>
    </statBases>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <drawAimPie>false</drawAimPie>
      <warmupTime>1.25</warmupTime>
      <requireLineOfSight>false</requireLineOfSight>
      <nonInterruptingSelfCast>true</nonInterruptingSelfCast>
      <soundCast>LBD_Angry_Bluefire_Switch_voice</soundCast>
      <targetable>false</targetable>
      <targetParams>
        <canTargetSelf>true</canTargetSelf>
      </targetParams>
    </verbProperties>
    <comps>
      <li Class="CompProperties_AbilityEffecterOnCaster" MayRequire="Ludeon.Rimworld.Odyssey">
        <effecterDef>WarTrumpet</effecterDef>
        <maintainTicks>20</maintainTicks>        <!-- Long enough for the "2nd wave" to spawn -->
      </li>
      <li Class="CompProperties_AbilityGiveHediff">
        <compClass>CompAbilityEffect_GiveHediff</compClass>
        <hediffDef>LBD_Angry_Bluefire</hediffDef>
        <onlyApplyToSelf>True</onlyApplyToSelf>
        <replaceExisting>true</replaceExisting>
      </li>
    </comps>
  </AbilityDef>

  <AbilityDef>
    <defName>LBD_SustainedFlameCone</defName>
    <label>扇形龙焰</label>
    <description>黑龙经过短暂蓄力后，持续向前方扇形区域喷射龙焰。她所喷射的龙焰是由非自然力量形成的，无论是肉体还是钢铁都会在其怒火下化为灰烬。\n\n如果进入核心超压状态，黑龙喷射的火焰将转变为蓝紫色火焰，并且伤害和穿甲能力得到大幅提升。</description>
    <iconPath>UI/Abilities/FireSpew</iconPath>
    <jobDef>LBD_CastAbilityMaintainFlame</jobDef>
    <waitForJobEnd>true</waitForJobEnd>
    <aiCanUse>true</aiCanUse>
    <ai_IsIncendiary>true</ai_IsIncendiary>
    <hostile>true</hostile>
    <casterMustBeCapableOfViolence>true</casterMustBeCapableOfViolence>
    <warmupStartSound>LBD_Dragon_Ability_Warmup</warmupStartSound>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>22.9</range>
      <warmupTime>0.6</warmupTime>
      <targetParams>
        <canTargetLocations>true</canTargetLocations>
      </targetParams>
    </verbProperties>
    <cooldownTicksRange>3000~3000</cooldownTicksRange>
    <comps>
      <li Class="LegendaryBlackDragon.CompProperties_AbilitySustainedFlameCone">
        <!-- ===== 核心判定（伤害）===== -->
        <!-- 伤害扇形最大距离（格） -->
        <range>22.9</range>
        <!-- 伤害扇形在最远端的宽度（格） -->
        <lineWidthEnd>12</lineWidthEnd>
        <!-- 伤害类型与单次脉冲伤害 -->
        <damageDef>LBD_DRM_Flame</damageDef>
        <damageAmount>12</damageAmount>
        <armorPenetration>1</armorPenetration>
        <filthDef>Filth_Ash</filthDef>
        <!-- 施法开始后第几 tick 开始造成伤害 -->
        <startDamageTick>1</startDamageTick>
        <!-- 每隔多少 tick 造成一次伤害 -->
        <damageIntervalTicks>6</damageIntervalTicks>
        
        <!-- ===== 持续时长 ===== -->
        <!-- 最长持续时间（tick，60tick=1秒） -->
        <!-- 180 tick = 3 秒 -->
        <maxSustainTicks>180</maxSustainTicks>
        
        <!-- ===== 视觉喷流（Burner风格）===== -->
        <!-- 视觉刷新间隔（tick） -->
        <visualIntervalTicks>3</visualIntervalTicks>
        <!-- 末端喷流附加特效 -->
        <effecterDef>LBD_BurnerUsed_Long</effecterDef>
        <moteDef>LBD_Mote_IncineratorBurst_Long</moteDef>
        <!-- 单次喷流条数 -->
        <numStreams>15</numStreams>
        <!-- 视觉扇形半角（总角度=2倍；24表示总48°） -->
        <coneSizeDegrees>16</coneSizeDegrees>
        <!-- 视觉长度在伤害射程基础上的额外偏移 -->
        <visualRangeOffset>1</visualRangeOffset>
        <visualLengthMultiplier>2</visualLengthMultiplier>
        <!-- 视觉喷流长度随机噪声 -->
        <rangeNoise>0.4</rangeNoise>
        <!-- 火焰从施法者前方多远位置发射（视觉） -->
        <barrelOffsetDistance>8</barrelOffsetDistance>
        <!-- 视觉缩放阈值（越小越容易显得“短粗”） -->
        <sizeReductionDistanceThreshold>8</sizeReductionDistanceThreshold>
        <!-- 喷流寿命随机噪声 -->
        <lifespanNoise>40</lifespanNoise>
        
        <!-- ===== 其他 ===== -->
        <canHitFilledCells>true</canHitFilledCells>
        <affectCaster>false</affectCaster>

        <!-- ===== 状态列表 ===== -->
        <states>
          <li Class="LegendaryBlackDragon.FlameState">
            <hediffDef>LBD_Angry_Bluefire</hediffDef>
            <damageAmount>25</damageAmount>
            <armorPenetration>1.5</armorPenetration>
            <effecterDef>LBD_BurnerUsed_Long_Blue</effecterDef>
            <moteDef>LBD_Mote_IncineratorBurst_Long_Blue</moteDef>
          </li>
        </states>
      </li>
    </comps>
  </AbilityDef>

  <AbilityDef>
    <defName>LBD_SustainedFlameAura</defName>
    <label>环形龙焰</label>
    <description>黑龙经过短暂蓄力后，向地上喷射龙焰，龙焰会被大地反射，并灼烧周围一切。她所喷射的龙焰是由非自然力量形成的，无论是肉体还是钢铁都会在其怒火下化为灰烬。\n\n如果进入核心超压状态，黑龙喷射的火焰将转变为蓝紫色火焰，并且伤害和穿甲能力得到大幅提升。</description>
    <iconPath>UI/Abilities/FireBurst</iconPath>
    <jobDef>LBD_CastAbilityMaintainFlameAura</jobDef>
    <waitForJobEnd>true</waitForJobEnd>
    <targetRequired>false</targetRequired>
    <showCastingProgressBar>true</showCastingProgressBar>
    <aiCanUse>true</aiCanUse>
    <ai_IsIncendiary>true</ai_IsIncendiary>
    <ai_SearchAOEForTargets>true</ai_SearchAOEForTargets>
    <hostile>true</hostile>
    <casterMustBeCapableOfViolence>true</casterMustBeCapableOfViolence>
    <cooldownTicksRange>3000~3000</cooldownTicksRange>
    <warmupStartSound>LBD_Dragon_Ability_Warmup</warmupStartSound>
    <verbProperties>
      <verbClass>LegendaryBlackDragon.Verb_CastAbility_FlyingSustainedFlameAura</verbClass>
      <warmupTime>1</warmupTime>
      <range>8.9</range>
      <requireLineOfSight>false</requireLineOfSight>
      <drawAimPie>false</drawAimPie>
      <targetParams>
        <canTargetSelf>true</canTargetSelf>
      </targetParams>
    </verbProperties>
    <comps>
      <li Class="LegendaryBlackDragon.CompProperties_AbilitySustainedFlameAura">
        <!-- 圆形范围半径 -->
        <radius>8.9</radius>
        <!-- 伤害类型 -->
        <damageDef>LBD_DRM_Flame</damageDef>
        <damAmount>10</damAmount>
        <armorPenetration>1</armorPenetration>
        <filthDef>Filth_Ash</filthDef>
        <!-- 施法后第几 tick 开始伤害 -->
        <startDamageTick>1</startDamageTick>
        <!-- 每隔多少 tick 一次伤害脉冲 -->
        <damageIntervalTicks>10</damageIntervalTicks>
        <!-- 最长持续 tick（180 = 3秒） -->
        <maxSustainTicks>180</maxSustainTicks>
        <!-- 360° Effecter 特效 -->
        <effecterDef>LBD_Fire_Burst</effecterDef>
        <effecterIntervalTicks>5</effecterIntervalTicks>
        <effecterDurationTicks>17</effecterDurationTicks>
        <!-- 环形发射点数量 -->
        <effecterRingPoints>12</effecterRingPoints>
        <!-- 内圈发射起始距离（格） -->
        <effecterRingRadius>1.5</effecterRingRadius>
        <!-- 持续期间撒燃料概率 -->
        <fuelSpawnChancePerTick>0.15</fuelSpawnChancePerTick>
        <canHitFilledCells>true</canHitFilledCells>
        <affectCaster>false</affectCaster>
        <!-- 状态列表 -->
        <states>
          <!-- 火焰强化状态 -->
          <li Class="LegendaryBlackDragon.FlameAuraState">
            <hediffDef>LBD_Angry_Bluefire</hediffDef>
            <damAmount>25</damAmount>
            <armorPenetration>1.5</armorPenetration>
            <effecterDef>LBD_Fire_Burst_Blue</effecterDef>
            <fuelSpawnChancePerTick>0.5</fuelSpawnChancePerTick>
          </li>
        </states>
      </li>
    </comps>
  </AbilityDef>

  <AbilityDef>
    <defName>LBD_FireBall</defName>
    <label>火球喷射</label>
    <description>黑龙向目标位置喷射火球，火球在命中后会爆炸并造成范围性伤害。\n\n如果进入核心超压状态，黑龙喷射的火球将转变为蓝紫色火球，精准度下降但是一次性喷射三发，伤害和穿甲能力得到大幅提升。</description>
    <jobDef>LBD_Job_Dragon_Launch_FireBall</jobDef>
    <waitForJobEnd>true</waitForJobEnd>
    <iconPath>LegendaryBlackDragon/UI/Abilities/LBD_FireBall</iconPath>
    <cooldownTicksRange>1000</cooldownTicksRange>
    <aiCanUse>false</aiCanUse>
    <displayOrder>300</displayOrder>
    <displayGizmoWhileUndrafted>false</displayGizmoWhileUndrafted>
    <charges>3</charges>
    <cooldownPerCharge>true</cooldownPerCharge>
    <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
    <warmupStartSound>LBD_Dragon_Ability_Warmup</warmupStartSound>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>26</range>
      <warmupTime>0.6</warmupTime>
      <soundCast>LBD_FireBall_voice</soundCast>
      <targetParams>
        <canTargetLocations>true</canTargetLocations>
      </targetParams>
    </verbProperties>
    <comps>
      <li Class="LegendaryBlackDragon.CompProperties_AbilityLaunchMultiProjectile">
        <!-- 默认状态参数 -->
        <projectileDef>LBD_FireBall_Proj</projectileDef>
        <numProjectiles>1</numProjectiles>
        
        <!-- 偏移配置 -->
        <offsetRadius>0</offsetRadius>
        <useRandomOffset>true</useRandomOffset>
        <offsetInCircle>true</offsetInCircle>
        <avoidOverlap>false</avoidOverlap>
        <shotIntervalTicks>15</shotIntervalTicks>
        
        <states>
          <li Class="LegendaryBlackDragon.ProjectileState">
            <hediffDef>LBD_Angry_Bluefire</hediffDef>
            <numProjectiles>3</numProjectiles>
            <projectileDef>LBD_FireBall_Blue_Proj</projectileDef>
            <offsetRadius>4.9</offsetRadius>
          </li>
        </states>
      </li>
    </comps>
  </AbilityDef>
  <ThingDef ParentName="BaseBullet">
    <defName>LBD_FireBall_Proj</defName>
    <label>火球</label>
    <thingClass>Projectile_Explosive</thingClass>
    <graphicData>
      <texPath>LegendaryBlackDragon/Mote/LBD_Fireball_Mote</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>MoteGlow</shaderType>
      <color>(0.9,0.3,0.2)</color>
      <drawSize>(2.2, 3)</drawSize>
    </graphicData>
    <projectile>
      <damageDef>LBD_DRM_Flame</damageDef>
      <damageAmountBase>30</damageAmountBase>
      <speed>65</speed>
      <!-- <soundAmbient>FleshmelterBolt_Launch</soundAmbient> -->
      <explosionRadius>3.49</explosionRadius>
      <screenShakeFactor>0.75</screenShakeFactor>
      <explosionChanceToStartFire>1</explosionChanceToStartFire>
      <armorPenetrationBase>1</armorPenetrationBase>
      <preExplosionSpawnSingleThingDef>Filth_BlastMark</preExplosionSpawnSingleThingDef>
      <!-- <flyOverhead>true</flyOverhead> -->
    </projectile>
  </ThingDef>
  <ThingDef ParentName="BaseBullet">
    <defName>LBD_FireBall_Blue_Proj</defName>
    <label>火球</label>
    <thingClass>Projectile_Explosive</thingClass>
    <graphicData>
      <texPath>LegendaryBlackDragon/Mote/LBD_Fireball_Mote</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>MoteGlow</shaderType>
      <color>(0.15,0.15,0.85)</color>
      <drawSize>(2.2, 3)</drawSize>
    </graphicData>
    <projectile>
      <damageDef>LBD_DRM_Flame</damageDef>
      <damageAmountBase>50</damageAmountBase>
      <speed>65</speed>
      <!-- <soundAmbient>FleshmelterBolt_Launch</soundAmbient> -->
      <explosionRadius>3.49</explosionRadius>
      <screenShakeFactor>0.5</screenShakeFactor>
      <explosionChanceToStartFire>1</explosionChanceToStartFire>
      <armorPenetrationBase>1.5</armorPenetrationBase>
      <preExplosionSpawnSingleThingDef>Filth_BlastMark</preExplosionSpawnSingleThingDef>
      <!-- <flyOverhead>true</flyOverhead> -->
    </projectile>
  </ThingDef>
</Defs>