<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <AbilityDef>
    <defName>LBD_SustainedFlameCone</defName>
    <label>sustained flame cone</label>
    <description>After a short charge, continuously breathes a cone of flame while the caster maintains focus.</description>
    <iconPath>UI/Abilities/FireSpew</iconPath>
    <jobDef>LBD_CastAbilityMaintainFlame</jobDef>
    <waitForJobEnd>true</waitForJobEnd>
    <aiCanUse>true</aiCanUse>
    <ai_IsIncendiary>true</ai_IsIncendiary>
    <hostile>true</hostile>
    <casterMustBeCapableOfViolence>true</casterMustBeCapableOfViolence>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>22.9</range>
      <warmupTime>0.6</warmupTime>
      <targetParams>
        <canTargetLocations>true</canTargetLocations>
      </targetParams>
    </verbProperties>
    <cooldownTicksRange>900~900</cooldownTicksRange>
    <comps>
      <li Class="LegendaryBlackDragon.CompProperties_AbilitySustainedFlameCone">
        <!-- ===== 核心判定（伤害）===== -->
        <!-- 伤害扇形最大距离（格） -->
        <range>22.9</range>
        <!-- 伤害扇形在最远端的宽度（格） -->
        <lineWidthEnd>12</lineWidthEnd>
        <!-- 伤害类型与单次脉冲伤害 -->
        <damageDef>LBD_DRM_Flame</damageDef>
        <damageAmount>12</damageAmount>
        <armorPenetration>1</armorPenetration>
        <filthDef>Filth_Ash</filthDef>
        <!-- 施法开始后第几 tick 开始造成伤害 -->
        <startDamageTick>1</startDamageTick>
        <!-- 每隔多少 tick 造成一次伤害 -->
        <damageIntervalTicks>6</damageIntervalTicks>
        
        <!-- ===== 持续时长 ===== -->
        <!-- 最长持续时间（tick，60tick=1秒） -->
        <!-- 180 tick = 3 秒 -->
        <maxSustainTicks>180</maxSustainTicks>
        
        <!-- ===== 视觉喷流（Burner风格）===== -->
        <!-- 视觉刷新间隔（tick） -->
        <visualIntervalTicks>3</visualIntervalTicks>
        <!-- 末端喷流附加特效 -->
        <effecterDef>LBD_BurnerUsed_Long</effecterDef>
        <moteDef>LBD_Mote_IncineratorBurst_Long</moteDef>
        <!-- 单次喷流条数 -->
        <numStreams>15</numStreams>
        <!-- 视觉扇形半角（总角度=2倍；24表示总48°） -->
        <coneSizeDegrees>16</coneSizeDegrees>
        <!-- 视觉长度在伤害射程基础上的额外偏移 -->
        <visualRangeOffset>1</visualRangeOffset>
        <visualLengthMultiplier>2</visualLengthMultiplier>
        <!-- 视觉喷流长度随机噪声 -->
        <rangeNoise>0.4</rangeNoise>
        <!-- 火焰从施法者前方多远位置发射（视觉） -->
        <barrelOffsetDistance>6</barrelOffsetDistance>
        <!-- 视觉缩放阈值（越小越容易显得“短粗”） -->
        <sizeReductionDistanceThreshold>8</sizeReductionDistanceThreshold>
        <!-- 喷流寿命随机噪声 -->
        <lifespanNoise>40</lifespanNoise>
        
        <!-- ===== 其他 ===== -->
        <canHitFilledCells>true</canHitFilledCells>
        <affectCaster>false</affectCaster>
      </li>
    </comps>
  </AbilityDef>

  <AbilityDef>
    <defName>LBD_SustainedFlameAura</defName>
    <label>sustained flame aura</label>
    <description>Erupts in a sustained burst of flame in all directions, scorching everything nearby while the caster maintains focus.</description>
    <iconPath>UI/Abilities/FireBurst</iconPath>
    <jobDef>LBD_CastAbilityMaintainFlameAura</jobDef>
    <waitForJobEnd>true</waitForJobEnd>
    <targetRequired>false</targetRequired>
    <showCastingProgressBar>true</showCastingProgressBar>
    <aiCanUse>true</aiCanUse>
    <ai_IsIncendiary>true</ai_IsIncendiary>
    <ai_SearchAOEForTargets>true</ai_SearchAOEForTargets>
    <hostile>true</hostile>
    <casterMustBeCapableOfViolence>true</casterMustBeCapableOfViolence>
    <cooldownTicksRange>900~900</cooldownTicksRange>
    <verbProperties>
      <verbClass>LegendaryBlackDragon.Verb_CastAbility_FlyingSustainedFlameAura</verbClass>
      <warmupTime>1</warmupTime>
      <range>8.9</range>
      <requireLineOfSight>false</requireLineOfSight>
      <drawAimPie>false</drawAimPie>
      <targetParams>
        <canTargetSelf>true</canTargetSelf>
      </targetParams>
    </verbProperties>
    <comps>
      <li Class="LegendaryBlackDragon.CompProperties_AbilitySustainedFlameAura">
        <!-- 圆形范围半径 -->
        <radius>8.9</radius>
        <!-- 伤害类型 -->
        <damageDef>LBD_DRM_Flame</damageDef>
        <damAmount>10</damAmount>
        <armorPenetration>1</armorPenetration>
        <filthDef>Filth_Ash</filthDef>
        <!-- 施法后第几 tick 开始伤害 -->
        <startDamageTick>1</startDamageTick>
        <!-- 每隔多少 tick 一次伤害脉冲 -->
        <damageIntervalTicks>10</damageIntervalTicks>
        <!-- 最长持续 tick（180 = 3秒） -->
        <maxSustainTicks>180</maxSustainTicks>
        <!-- 360° Effecter 特效 -->
        <effecterDef>LBD_Fire_Burst</effecterDef>
        <effecterIntervalTicks>5</effecterIntervalTicks>
        <effecterDurationTicks>17</effecterDurationTicks>
        <!-- 环形发射点数量 -->
        <effecterRingPoints>12</effecterRingPoints>
        <!-- 内圈发射起始距离（格） -->
        <effecterRingRadius>1.5</effecterRingRadius>
        <!-- 持续期间撒燃料概率 -->
        <fuelSpawnChancePerTick>0.15</fuelSpawnChancePerTick>
        <canHitFilledCells>true</canHitFilledCells>
        <affectCaster>false</affectCaster>
      </li>
    </comps>
  </AbilityDef>

  <AbilityDef>
    <defName>LBD_FireBall</defName>
    <label>火球喷射</label>
    <description>黑龙向目标位置喷射一发火球，火球在命中后会爆炸并造成范围性伤害。</description>
    <iconPath>UI/Abilities/FireBurst</iconPath>
    <cooldownTicksRange>5000</cooldownTicksRange>
    <aiCanUse>false</aiCanUse>
    <displayOrder>300</displayOrder>
    <displayGizmoWhileUndrafted>false</displayGizmoWhileUndrafted>
    <charges>3</charges>
    <cooldownPerCharge>true</cooldownPerCharge>
    <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
    <!-- <warmupStartSound>AcidSpray_Warmup</warmupStartSound> -->
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>26</range>
      <warmupTime>0.25</warmupTime>
      <!-- <soundCast>AcidSpray_Resolve</soundCast> -->
      <targetParams>
        <canTargetLocations>true</canTargetLocations>
      </targetParams>
    </verbProperties>
    <comps>
      <li Class="CompProperties_AbilityLaunchProjectile">
        <projectileDef>LBD_FireBall_Proj</projectileDef>
      </li>
    </comps>
  </AbilityDef>
  <ThingDef ParentName="BaseBullet">
    <defName>LBD_FireBall_Proj</defName>
    <label>火球</label>
    <thingClass>Projectile_Explosive</thingClass>
    <graphicData>
      <texPath>LegendaryBlackDragon/Mote/LBD_Fireball_Mote</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>MoteGlow</shaderType>
      <drawSize>(2.5, 3)</drawSize>
    </graphicData>
    <projectile>
      <damageDef>LBD_DRM_Flame</damageDef>
      <damageAmountBase>30</damageAmountBase>
      <speed>65</speed>
      <!-- <soundAmbient>FleshmelterBolt_Launch</soundAmbient> -->
      <explosionRadius>3.49</explosionRadius>
      <screenShakeFactor>0.75</screenShakeFactor>
      <explosionChanceToStartFire>1</explosionChanceToStartFire>
      <armorPenetrationBase>1</armorPenetrationBase>
      <preExplosionSpawnSingleThingDef>Filth_BlastMark</preExplosionSpawnSingleThingDef>
      <!-- <flyOverhead>true</flyOverhead> -->
    </projectile>
  </ThingDef>
  
  <AbilityDef>
    <defName>LBD_Dragon_Charge</defName>
    <label>龙车冲锋</label>
    <description>黑龙以自身为武器，快速向前撞击。尽管因为身体变小破坏力大不如前，但是依然能将敌人顶个七荤八素。</description>
    <iconPath>UI/Abilities/FireBurst</iconPath>
    <cooldownTicksRange>6000</cooldownTicksRange>
    <charges>2</charges>
    <cooldownPerCharge>true</cooldownPerCharge>
    <aiCanUse>false</aiCanUse>
    <verbProperties>
      <verbClass>LegendaryBlackDragon.Verb_CastAbilityTrackingCharge</verbClass>
      <requireLineOfSight>false</requireLineOfSight>
      <targetParams>
        <canTargetPawns>true</canTargetPawns>
        <canTargetBuildings>true</canTargetBuildings>
        <canTargetAnimals>true</canTargetAnimals>
        <canTargetMechs>true</canTargetMechs>
        <canTargetSelf>false</canTargetSelf>
      </targetParams>
      <range>18</range>
      <warmupTime>1.0</warmupTime>
    </verbProperties>
    <comps>
      <li Class="LegendaryBlackDragon.CompProperties_TrackingCharge">
        <homingSpeed>1.5</homingSpeed>
        <initialDamage>15</initialDamage>
        <damagePerTile>1.5</damagePerTile>
        <inertiaDistance>6</inertiaDistance>
        <collisionDamageDef>Demolish</collisionDamageDef>
        <flyerDef>LBD_Flyer_TrackingCharge</flyerDef>
        <collisionRadius>1.5</collisionRadius>        <!-- Larger collision radius -->
        <impactSound>Pawn_Melee_BigBash_HitPawn</impactSound>
        <damageHostileOnly>true</damageHostileOnly>        <!-- Set to false to damage everyone in the path -->
      </li>
      <li Class="CompProperties_AbilityEffecterOnCaster">
        <effecterDef>WarTrumpet</effecterDef>
        <maintainTicks>20</maintainTicks>        <!-- Long enough for the "2nd wave" to spawn -->
      </li>
    </comps>
  </AbilityDef>
  <ThingDef ParentName="PawnFlyerBase">
    <defName>LBD_Flyer_TrackingCharge</defName>
    <thingClass>LegendaryBlackDragon.PawnFlyer_TrackingCharge</thingClass>
    <pawnFlyer>
      <flightSpeed>1.5</flightSpeed>
      <heightFactor>0</heightFactor>
    </pawnFlyer>
  </ThingDef>
</Defs>