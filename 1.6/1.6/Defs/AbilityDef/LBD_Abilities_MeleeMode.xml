<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <AbilityDef>
    <defName>LBD_ToggleMeleeMode</defName>
    <label>切换拍击/挠击</label>
    <description>黑龙在两种近战状态下切换：拍击与挠击，切换是随时完成且没有成本的。\n\n在拍击状态下，黑龙所有的近战攻击都会伤害一片区域内的所有敌人；\n\n在挠击状态下，黑龙的近战会将敌人击飞。</description>
    <iconPath>LegendaryBlackDragon/UI/Abilities/LBD_ToggleMeleeMode</iconPath>
    <targetRequired>false</targetRequired>
    <displayGizmoWhileUndrafted>true</displayGizmoWhileUndrafted>
    <disableGizmoWhileUndrafted>false</disableGizmoWhileUndrafted>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <warmupTime>0</warmupTime>
      <targetParams>
        <canTargetSelf>true</canTargetSelf>
      </targetParams>
    </verbProperties>
    <cooldownTicksRange>30~30</cooldownTicksRange>
    <comps>
      <li Class="LegendaryBlackDragon.CompProperties_AbilityToggleMeleeMode" />
    </comps>
  </AbilityDef>
</Defs>
