<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <NeedDef>
    <defName>Need_LBD_BlackDragon</defName>
    <label>Incineration</label>
    <description>Miraboreasu doesn't have a very good temper. She prefers to burn the pests who challenge her with endless fire, rather than planting vegetables or mining in the wild. If this need is too low, she will try to go outside the residential area to burn flammable objects for fun—using her fire-breathing skills can also satisfy the need.</description>
    <listPriority>800</listPriority>
    <showOnNeedList>true</showOnNeedList>
    <major>true</major>
    <showForCaravanMembers>true</showForCaravanMembers>
    <showUnitTicks>true</showUnitTicks>
    <freezeWhileSleeping>true</freezeWhileSleeping>
    <minIntelligence>Humanlike</minIntelligence>
    <needClass>LegendaryBlackDragon.Need_BlackDragon</needClass>
    <onlyIfCausedByTrait>true</onlyIfCausedByTrait>
    
    <!-- ModExtension 配置 -->
    <modExtensions>
      <li Class="LegendaryBlackDragon.NeedExtension_BlackDragon">
        <!-- 阶段 Thought 配置 -->
        <stage1Thought>Thought_BlackDragon_Stage1</stage1Thought>
        <stage2Thought>Thought_BlackDragon_Stage2</stage2Thought>
        <stage3Thought>Thought_BlackDragon_Stage3</stage3Thought>
        <stage4Thought>Thought_BlackDragon_Stage4</stage4Thought>
        
        <!-- 阶段阈值 -->
        <stage4Threshold>0.7</stage4Threshold>
        <stage3Threshold>0.50</stage3Threshold>
        <stage2Threshold>0.25</stage2Threshold>
        <stage1Threshold>0.0</stage1Threshold>
        
        <!-- Need 恢复配置 -->
        <baseFallRatePerDay>-0.20</baseFallRatePerDay>
        <fireStartingGain>1</fireStartingGain>
        
        <!-- 点火行为配置 -->
        <allowFireStarting>true</allowFireStarting>
        <minFireStartingNeed>0.40</minFireStartingNeed>
        <onlyOutsideHomeArea>true</onlyOutsideHomeArea>
        
        <!-- 紧急状态配置 -->
        <emergencyFireStarting>true</emergencyFireStarting>
        <emergencyThreshold>0.15</emergencyThreshold>
        <emergencyFireGain>0.25</emergencyFireGain>
        
        <!-- 冷却时间 -->
        <fireCooldownTicks>6000</fireCooldownTicks>
        
        <!-- 阶段持续时间乘数 -->
        <stageDurationMultiplier>1.0</stageDurationMultiplier>

        
        <!-- === 新增：Hediff 配置 === -->
        <!-- 火焰活动 Hediff -->
        <fireActivityHediff>LBD_Need_LBD_BlackDragon_Change</fireActivityHediff>
        <!-- 拥有 Hediff 时每秒恢复的 Need 值 -->
        <hediffNeedGainPerSecond>0.1</hediffNeedGainPerSecond>
      </li>
    </modExtensions>
  </NeedDef>

  <ThoughtDef>
    <defName>Thought_BlackDragon_Stage1</defName>
    <thoughtClass>LegendaryBlackDragon.Thought_BlackDragon_Stage1</thoughtClass>
    <stackLimit>1</stackLimit>
    <stages>
      <li>
        <label>Destruction Thirst</label>
        <description>This colony is SO! BORED! — I'm going to find something to burn.</description>
        <baseMoodEffect>-20</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>
  <ThoughtDef>
    <defName>Thought_BlackDragon_Stage2</defName>
    <thoughtClass>LegendaryBlackDragon.Thought_BlackDragon_Stage2</thoughtClass>
    <stackLimit>1</stackLimit>
    <stages>
      <li>
        <label>Destruction Desire</label>
        <description>So bored, want to burn something...</description>
        <baseMoodEffect>-5</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>
  <ThoughtDef>
    <defName>Thought_BlackDragon_Stage3</defName>
    <thoughtClass>LegendaryBlackDragon.Thought_BlackDragon_Stage3</thoughtClass>
    <stackLimit>1</stackLimit>
    <stages>
      <li>
        <label>Flame Satisfaction</label>
        <description>At least this colony can provide me with some other fun.</description>
        <baseMoodEffect>3</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>
  <ThoughtDef>
    <defName>Thought_BlackDragon_Stage4</defName>
    <thoughtClass>LegendaryBlackDragon.Thought_BlackDragon_Stage4</thoughtClass>
    <stackLimit>1</stackLimit>
    <stages>
      <li>
        <label>Flame Pleasure</label>
        <description>BURN TO DEATH!</description>
        <baseMoodEffect>10</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>
</Defs>